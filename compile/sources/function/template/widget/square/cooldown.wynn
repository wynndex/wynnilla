cooldown_condition cooldown_value texture
if({:cooldown_condition};
    concat_st(
        {$widget_square_cooldown^{:offset}};
        {$pan@-13};
        {$pan@6};
        {text/widget/prefix({:cooldown_value})};
        {text/widget/content/square({:cooldown_value})};
        {text/widget/suffix({:cooldown_value})};
        {$pan@-6}
    );
    concat_st(
        {${:texture}@0^{:offset}};
        {$pan@-13}
    )
)